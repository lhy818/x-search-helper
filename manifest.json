{
  "manifest_version": 3,
  "name": "X Search Helper - 高级搜索模板",
  "version": "1.0.0",
  "description": "一键使用高级搜索模板，快速找到X/Twitter上的爆款内容",
  "author": "苦工团队",
  
  "permissions": [
    "storage",
    "activeTab"
  ],
  
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "X Search Helper",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "web_accessible_resources": [
    {
      "resources": ["templates/*"],
      "matches": ["https://x.com/*", "https://twitter.com/*"]
    }
  ]
}